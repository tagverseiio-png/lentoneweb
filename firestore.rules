rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Page Content: Anyone can read, only authenticated write (or Admin SDK)
    match /pageContent/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Products: Anyone can read, only authenticated write (or Admin SDK)
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. SEO: Anyone can read, only authenticated write (or Admin SDK)
    match /seo/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Enquiries: Anyone can submit (create), only authenticated can read/update/delete (or Admin SDK)
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 5. Admin: Strictly protected, only authenticated (or Admin SDK)
    match /admin/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
